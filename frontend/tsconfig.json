{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",  // Keep bundler mode if using a bundler like Vite
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "outDir": "./dist",  // Specify the output directory

    /* Emit JavaScript */
    "noEmit": false,  // Ensure JavaScript is emitted
    
    /* Linting */
    "strict": true,
    "noUnusedLocals": false,  // Allow unused locals for now
    "noUnusedParameters": false,  // Allow unused function parameters
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
